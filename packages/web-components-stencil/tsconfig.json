{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "outDir": "dist",
    "jsx": "react",
    "jsxFactory": "h",
    "module": "Preserve",
    "moduleResolution": "bundler"
  },
  "include": ["src", "stencil.config.ts"],
  "exclude": ["**/node_modules/*", "**/*.spec.ts", "**/*.spec.tsx"]
}
